  - 64
  - 128
  - 128
  num_res_blocks:
  - 3
  - 3
  - 3
  - 9
  - 3
  name: cnn
  objective: jepa
  use_channel_stem: true
  use_temporal_mixer: true
  predictor_scale_factor: 3
  predictor_depth: 2
ft:
  num_epochs: 100
  lr: 0.001
  batch_size: 16
  report_every: 100
  save_every: 10
  head_type: linear
  embeddings_dir: ./embeddings/full_A1_A2_A3_A4
  task: regression
  use_attentive_pooling: false
  lr_scheduler: cosine
  lr_scheduler_warmup_epochs: 2
  min_lr: 0
  weight_decay: 0.01
  noise_std: 0.0
  run_name: full-linear-178354
  distributed: false
train:
  run_name: eval-upgraded
  num_epochs: 5
  batch_size: 4
  report_every: 100
  save_every: 2
  include_labels: false
  sim_coeff: 2
  std_coeff: 40
  cov_coeff: 2
  predict_n_steps: false
  lr_scheduler: cosine
  lr_scheduler_warmup_epochs: 2
  min_lr: 1.0e-06
  lr: 0.001
  weight_decay: 0.05
  noise_std: 1.0
  distributed: false
out_path: ./checkpoints/upgraded-linear-probe
cache_path: ./dataset_cache
dry_run: false
seed: 42

