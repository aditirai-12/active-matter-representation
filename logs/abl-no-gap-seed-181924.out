  lr_scheduler: cosine
  lr_scheduler_warmup_epochs: 2
  min_lr: 1.0e-06
  lr: 0.001
  weight_decay: 0.05
  noise_std: 1.0
  run_name: ablation-no-gap-seed
  distributed: true
  target_global_batch_size: 8
out_path: ./checkpoints/ablation-no-gap-seed
cache_path: ./dataset_cache
seed: 0
dry_run: false

