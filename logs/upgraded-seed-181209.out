dataset:
  name: active_matter
  num_frames: 16
  num_frames_per_patch: 2
  num_chans: 11
  resolution: 224
  offset: 1
  gap_frames: 8
model:
  dims:
  - 32
  - 64
  - 128
  - 256
  - 256
  num_res_blocks:
  - 3
  - 3
  - 3
  - 9
  - 3
  name: cnn
  objective: jepa
  use_channel_stem: true
  use_temporal_mixer: true
  predictor_scale_factor: 3
  predictor_depth: 2
  preserve_temporal: true
ft:
  num_epochs: 100
  lr: 0.001
  batch_size: 32
  report_every: 100
  save_every: 10
  head_type: linear
  embeddings_dir: ./embeddings
  task: regression
  lr_scheduler: cosine
  lr_scheduler_warmup_epochs: 2
  min_lr: 0
  weight_decay: 0.01
  noise_std: 1.0
  run_name: upgraded-jepa-FT
  distributed: false
train:
  start_epoch: 0
  num_epochs: 30
  batch_size: 2
  report_every: 100
  save_every: 2
  include_labels: false
  sim_coeff: 10
  std_coeff: 10
  cov_coeff: 1
  predict_n_steps: false
  lr_scheduler: cosine
  lr_scheduler_warmup_epochs: 2
  min_lr: 1.0e-06
  lr: 0.001
  weight_decay: 0.05
  noise_std: 1.0
  run_name: upgraded-jepa
  distributed: true
  target_global_batch_size: 8
out_path: ./checkpoints/upgraded-jepa
cache_path: ./dataset_cache
seed: 42
dry_run: false

