dataset:
  name: active_matter
  num_frames: 8
  num_frames_per_patch: 2
  num_chans: 11
  resolution: 224
  offset: 1
  gap_frames: 8
model:
  dims:
  - 16
  - 32
  - 64
  - 128
  - 128
  num_res_blocks:
  - 3
  - 3
  - 3
  - 9
  - 3
  name: cnn
  objective: jepa
  use_channel_stem: false
  use_temporal_mixer: false
  predictor_scale_factor: 2
  predictor_depth: 1
ft:
  num_epochs: 100
  lr: 0.001
  batch_size: 16
  report_every: 100
  save_every: 10
  head_type: linear
  embeddings_dir: ./embeddings/A1
  task: regression
  use_attentive_pooling: false
  lr_scheduler: cosine
  lr_scheduler_warmup_epochs: 2
  min_lr: 0
  weight_decay: 0.01
  noise_std: 0.0
  run_name: A1-linear-178332
  distributed: false
train:
  run_name: eval-upgraded
  num_epochs: 5
  batch_size: 4
  report_every: 100
  save_every: 2
  include_labels: false
  sim_coeff: 2
  std_coeff: 40
  cov_coeff: 2
  predict_n_steps: false
  lr_scheduler: cosine
  lr_scheduler_warmup_epochs: 2
  min_lr: 1.0e-06
  lr: 0.001
  weight_decay: 0.05
  noise_std: 1.0
  distributed: false
out_path: ./checkpoints/upgraded-linear-probe
cache_path: ./dataset_cache
dry_run: false
seed: 42

