  name: cnn
  objective: jepa
  use_channel_stem: true
  use_temporal_mixer: true
  predictor_scale_factor: 3
  predictor_depth: 2
  preserve_temporal: false
ft:
  num_epochs: 100
  lr: 0.001
  batch_size: 32
  report_every: 100
  save_every: 10
  head_type: linear
  embeddings_dir: ./embeddings
  task: regression
  lr_scheduler: cosine
  lr_scheduler_warmup_epochs: 2
  min_lr: 0
