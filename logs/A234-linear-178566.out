  - 3
  name: cnn
  objective: jepa
  use_channel_stem: true
  use_temporal_mixer: true
  predictor_scale_factor: 3
  predictor_depth: 2
ft:
  num_epochs: 100
  lr: 0.001
  batch_size: 16
  report_every: 100
  save_every: 10
  head_type: linear
